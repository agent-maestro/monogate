{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://capcard.ai/schema/v1.json",
  "title": "CapCard v1",
  "description": "Machine-verifiable capability card for AI-readable software discovery.",
  "type": "object",
  "required": ["card_version", "name", "version", "tagline", "capabilities", "artifacts"],
  "properties": {
    "card_version": { "type": "string" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "tagline": { "type": "string", "maxLength": 120 },
    "capabilities": {
      "type": "object",
      "properties": {
        "symbolic_regression": {
          "type": "object",
          "properties": {
            "description": { "type": "string" },
            "operators": { "type": "array", "items": { "type": "string" } },
            "search_methods": { "type": "array", "items": { "type": "string" } }
          }
        },
        "physics_laws": {
          "type": "object",
          "properties": {
            "count": { "type": "integer" },
            "exact_zero_error": { "type": "integer" },
            "catalog": { "type": "array", "items": { "type": "string" } }
          }
        },
        "special_functions": {
          "type": "object",
          "properties": {
            "count": { "type": "integer" },
            "exact_cbest": { "type": "integer" }
          }
        },
        "test_count": { "type": "integer" },
        "sin_barrier": {
          "type": "object",
          "properties": {
            "n_trees_searched": { "type": "integer" },
            "sin_absent": { "type": "boolean" },
            "max_n": { "type": "integer" }
          }
        },
        "eml_fourier": {
          "type": "object",
          "properties": {
            "sin_approx_K": { "type": "integer" },
            "sin_mse_train": { "type": "number" },
            "sin_mse_test": { "type": "number" }
          }
        }
      }
    },
    "benchmarks": {
      "type": "object",
      "properties": {
        "srbench": {
          "type": "object",
          "properties": {
            "datasets_tested": { "type": "integer" },
            "mean_r2": { "type": "number" }
          }
        }
      }
    },
    "reproduce": {
      "type": "object",
      "properties": {
        "install": { "type": "string" },
        "test": { "type": "string" },
        "docker": { "type": "string" }
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["github"],
      "properties": {
        "arxiv": { "type": "string" },
        "pypi": { "type": "string" },
        "github": { "type": "string" }
      }
    }
  }
}
