    "wave_equation_solution": {
      "formula": "u(x,t) = f(x-ct) + g(x+ct)  (d'Alembert)",
      "eml_depth": "depth(f)",
      "reason": "EML depth of solution = EML depth of initial data f,g."
    },
    "burgers_cole_hopf": {
