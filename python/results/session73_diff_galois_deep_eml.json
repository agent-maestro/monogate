  "fuchsian_odes": [
    {
      "name": "Euler-Cauchy equation",
      "equation": "x\u00b2y'' + \u03b1xy' + \u03b2y = 0",
      "singular_points": [
        "0",
        "\u221e"
      ],
      "indicial_roots": [
        "r\u2081, r\u2082 roots of r(r-1)+\u03b1r+\u03b2=0"
      ],
      "eml_depth": 2,
      "eml_reason": "Solutions: x^{r\u2081}, x^{r\u2082} = exp(r\u00b7ln x) = EML-2",
      "solutions": [
        "y = x^{r\u2081} = exp(r\u2081\u00b7ln x)",
        "y = x^{r\u2082} if r\u2081-r\u2082 \u2209 \u2124, else x^{r\u2081}\u00b7ln(x)"
      ]
    },
    {
      "name": "Hypergeometric equation",
      "equation": "z(1-z)y'' + [c-(a+b+1)z]y' - ab\u00b7y = 0",
      "singular_points": [
        "0",
        "1",
        "\u221e"
      ],
      "indicial_roots": [
        "0",
        "1-c"
      ],
      "eml_depth": 3,
      "eml_reason": "\u2082F\u2081(a,b;c;z) \u2014 Euler integral representation \u2192 EML-3 for generic params",
      "solutions": [
        "\u2082F\u2081(a,b;c;z)",
        "z^{1-c}\u00b7\u2082F\u2081(a-c+1,b-c+1;2-c;z)"
      ]
    },
    {
      "name": "Legendre equation",
      "equation": "(1-x\u00b2)y'' - 2xy' + n(n+1)y = 0",
      "singular_points": [
        "-1",
        "1",
        "\u221e"
      ],
      "indicial_roots": [
        "0",
        "0"
      ],
      "eml_depth": 2,
      "eml_reason": "P_n(x) = Legendre polynomial (integer n) = polynomial \u2192 EML-2; Q_n has log \u2192 EML-2",
      "solutions": [
        "P_n(x) (polynomial, EML-2)",
        "Q_n(x) = P_n(x)\u00b7\u00bd\u00b7ln((1+x)/(1-x)) + poly \u2192 EML-2"
      ]
    },
    {
      "name": "Bessel equation (half-integer \u03bd)",
      "equation": "x\u00b2y'' + xy' + (x\u00b2-\u03bd\u00b2)y = 0, \u03bd = n+\u00bd",
      "singular_points": [
        "0",
        "\u221e"
      ],
      "indicial_roots": [
        "\u00b1\u03bd"
      ],
      "eml_depth": 3,
      "eml_reason": "j_n(x) = spherical Bessel = sin/cos \u00d7 polynomial / x^{n+1} \u2192 EML-3",
      "solutions": [
        "j_n(x) = (-x)^n(1/x d/dx)^n(sin x/x) \u2014 EML-3",
        "y_n(x) similarly EML-3"
      ]
    },
    {
      "name": "Bessel equation (general \u03bd)",
      "equation": "x\u00b2y'' + xy' + (x\u00b2-\u03bd\u00b2)y = 0, \u03bd \u2209 \u2124+\u00bd",
      "singular_points": [
        "0",
        "\u221e"
      ],
      "indicial_roots": [
        "\u00b1\u03bd"
      ],
      "eml_depth": "\u221e",
      "eml_reason": "J_\u03bd(x) = \u03a3(-1)^n x^{2n+\u03bd}/(n!\u0393(n+\u03bd+1)) \u2014 no closed EML-finite form for general \u03bd",
      "solutions": [
        "J_\u03bd(x)",
        "Y_\u03bd(x) \u2014 both EML-\u221e for non-half-integer \u03bd"
      ]
    },
    {
      "name": "Lam\u00e9 equation",
      "equation": "y'' + (n(n+1)\u00b7k\u00b2\u00b7sn\u00b2(x,k) + h)y = 0",
      "singular_points": [
        "e\u2081",
        "e\u2082",
        "e\u2083",
        "\u221e"
      ],
      "indicial_roots": [
        "depends on h,n,k"
      ],
      "eml_depth": "\u221e",
      "eml_reason": "Solutions are Lam\u00e9 functions \u2014 no general EML-finite form; EML-\u221e for generic parameters",
      "solutions": [
        "Ec_n^m(x,k)",
        "Es_n^m(x,k) \u2014 EML-\u221e for non-integer/non-special params"
      ]
    }
  ],
