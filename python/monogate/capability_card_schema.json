{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://monogate.org/schemas/capcard/v2.json",
  "title": "Monogate CapCard v2",
  "description": "Machine-verifiable capability card for the monogate package and research programme.",
  "type": "object",
  "required": [
    "capcard_version",
    "id",
    "name",
    "type",
    "description",
    "version",
    "license",
    "homepage",
    "repository",
    "capabilities",
    "benchmarks",
    "proofs",
    "verification",
    "metadata"
  ],
  "properties": {
    "capcard_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "id": { "type": "string" },
    "name": { "type": "string" },
    "type": { "type": "string" },
    "description": { "type": "string" },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[.+-].*)?$"
    },
    "license": { "type": "string" },
    "homepage": { "type": "string", "format": "uri" },
    "repository": { "type": "string", "format": "uri" },
    "lean_repo": { "type": "string", "format": "uri" },
    "related_sites": {
      "type": "object",
      "additionalProperties": { "type": "string", "format": "uri" }
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string" }
        }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "category", "description", "status"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "category": {
            "type": "string",
            "enum": [
              "scientific_claim",
              "cost_theory",
              "taxonomy",
              "lower_bound",
              "upper_bound",
              "construction",
              "empirical_dataset",
              "conjecture"
            ]
          },
          "description": { "type": "string" },
          "status": {
            "type": "string",
            "enum": [
              "proven",
              "proven_partial",
              "empirically_confirmed",
              "conjecture"
            ]
          },
          "constraints": { "type": "object" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "benchmarks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "metric", "value"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "capability_ref": { "type": "string" },
          "metric": { "type": "string" },
          "value": {},
          "unit": { "type": "string" },
          "direction": {
            "type": "string",
            "enum": ["higher_is_better", "lower_is_better"]
          },
          "reproducibility": {
            "type": "object",
            "properties": {
              "command": { "type": "string" },
              "deterministic": { "type": "boolean" }
            }
          },
          "notes": { "type": "string" }
        }
      }
    },
    "proofs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "statement", "status", "sorries"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "statement": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["proven_machine_verified", "proven_partial"]
          },
          "proof_method": { "type": "string" },
          "lean_file": { "type": "string" },
          "lean_theorem": { "type": "string" },
          "sorries": { "type": "integer", "minimum": 0 },
          "sorries_description": { "type": "string" },
          "capability_refs": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "required": ["test_count", "last_verified"],
      "properties": {
        "test_count": { "type": "integer", "minimum": 0 },
        "test_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "last_verified": { "type": "string", "format": "date-time" },
        "trust_score": {
          "type": "object",
          "properties": {
            "value": { "type": "number", "minimum": 0, "maximum": 1 },
            "version": { "type": "string" },
            "notes": { "type": "string" }
          }
        }
      }
    },
    "integration": {
      "type": "object",
      "properties": {
        "install": { "type": "object" },
        "sdk_languages": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["created", "updated"],
      "properties": {
        "created": { "type": "string", "format": "date-time" },
        "updated": { "type": "string", "format": "date-time" },
        "schema_url": { "type": "string", "format": "uri" }
      }
    }
  }
}
